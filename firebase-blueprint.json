{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "Basic profile information for the portfolio owner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "experience": { "type": "string" },
        "projectsCount": { "type": "number" },
        "companiesCount": { "type": "number" },
        "educationLevel": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "title"]
    },
    "Education": {
      "title": "Education",
      "description": "Education history.",
      "type": "object",
      "properties": {
        "degree": { "type": "string" },
        "institution": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["degree", "institution"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Professional certificates and participation records.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["title", "issuer"]
    },
    "Project": {
      "title": "Project",
      "description": "Portfolio projects.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["title"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact form messages.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "/profile/main": {
      "schema": "Profile",
      "description": "Main profile document."
    },
    "/education/{eduId}": {
      "schema": "Education",
      "description": "List of education entries."
    },
    "/certificates/{certId}": {
      "schema": "Certificate",
      "description": "List of certificates."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "List of projects."
    },
    "/messages/{msgId}": {
      "schema": "Message",
      "description": "Contact form submissions."
    }
  }
}
